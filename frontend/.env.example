# Copy this file to `.env` in the same directory and adjust as needed.
# `.env` is git-ignored; this example is the only version committed.
#
# Vite loads .env files from the frontend/ directory, which is why this
# lives here rather than at the repository root.
#
# The backend takes no environment variables at present — it is a
# self-contained FastAPI service with no external dependencies or secrets.

# Base URL of the backend API.
# Read by frontend/src/App.jsx via import.meta.env.VITE_API_BASE.
# Falls back to http://127.0.0.1:8000 when unset.
VITE_API_BASE=http://127.0.0.1:8000
